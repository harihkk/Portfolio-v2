# The Systems Journal, environment configuration
# Copy to .env.local and fill in. All values are OPTIONAL: the site builds and
# runs fully without any of them (integrations degrade gracefully to fallbacks).

# Canonical site URL (used for SEO, canonical links, sitemap, OG).
# No trailing slash. Defaults to the GitHub Pages origin if unset.
NEXT_PUBLIC_SITE_URL=https://harihkk.github.io

# Substack newsletter base URL (e.g. https://yourname.substack.com).
# When unset, all Substack UI is hidden, no broken feed, no fake posts.
NEXT_PUBLIC_SUBSTACK_URL=

# GitHub API token, optional. Lifts rate limits on the conservative repo
# metadata fetch (latest release / last update). Server-side only; never
# exposed to the browser. Repo rendering works without it via local fallbacks.
GITHUB_TOKEN=

# Contact form delivery (Resend). The form only sends when BOTH a key and a
# from-address are set; otherwise it cleanly falls back to the mailto link and
# never claims a delivery it cannot confirm.
RESEND_API_KEY=
CONTACT_FROM_EMAIL=
# Where contact messages are delivered. Defaults to the public contact email.
CONTACT_TO_EMAIL=
